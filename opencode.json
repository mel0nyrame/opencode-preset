{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-opencode-slim@latest",
    "@mohak34/opencode-notifier@latest"
  ],
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "mcp": {
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true
    },
    "officecli": {
      "type": "local",
      "command": [
        "officecli",
        "mcp"
      ],
      "enabled": true
    }
  },
  "provider": {}
}
